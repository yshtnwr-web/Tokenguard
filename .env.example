# TokenGuard Environment Variables
# Copy this file to .env and fill in your own values

# Dashboard authentication (HTTP Basic Auth)
DASHBOARD_USER=admin
DASHBOARD_PASS=choose-a-strong-password

# API Keys (optional – if not set, TokenGuard will look in config.json)
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# Server port (default 3000)
PORT=3000

# CORS allowed origins (comma-separated, no spaces)
# ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com